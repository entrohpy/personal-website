---
import { Image } from 'astro:assets';
import { SITE } from 'astrowind:config';
import logo from '~/assets/images/logo.png';
---

<span
  class="inline-flex items-center gap-2 self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-heading whitespace-nowrap"
>
  <Image src={logo} alt="" aria-hidden="true" width={256} height={256} class="w-7 h-7 rounded" loading="eager" />
  {SITE?.name}
</span>
