---
import '@fontsource-variable/sometype-mono';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Sometype Mono Variable';
    --aw-font-serif: 'Sometype Mono Variable';
    --aw-font-heading: 'Sometype Mono Variable';

    --aw-color-primary: rgb(86 91 129);
    --aw-color-secondary: rgb(86 91 180);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(24 24 24);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Sometype Mono Variable';
    --aw-font-serif: 'Sometype Mono Variable';
    --aw-font-heading: 'Sometype Mono Variable';

    --aw-color-primary: rgb(86 91 129);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(226 246 246);
    --aw-color-text-muted: rgb(226 246 246 / 80%);
    --aw-color-bg-page: rgb(24 24 24);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
