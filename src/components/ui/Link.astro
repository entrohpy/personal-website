---
import { twMerge } from 'tailwind-merge';
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'a'>, 'slot'> {
  text?: string;
  class?: string;
}

const { text = Astro.slots.render('default'), target, class: className = '', ...rest } = Astro.props;
---

<a
  class={twMerge('underline cursor-pointer hover:text-primary transition ease-in duration-200', className)}
  {...target ? { target: target, rel: 'noopener noreferrer' } : {}}
  {...rest}><Fragment set:html={text} /></a
>
